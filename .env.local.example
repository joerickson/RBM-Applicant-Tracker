# =============================================================
# RBM Applicant Tracker - Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================

# Supabase Project URL (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous (public) key - safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Supabase Service Role Key - KEEP SECRET, only for server-side/scripts
# Found in Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Resend API key (for email notifications)
# Sign up at https://resend.com
RESEND_API_KEY=re_your-resend-api-key-here

# Email address to send notifications from
# Must be a verified domain in Resend
RESEND_FROM_EMAIL=noreply@yourdomain.com

# HR notification email (receives alerts for new portal applications)
HR_NOTIFICATION_EMAIL=hr@yourdomain.com

# Next.js public site URL (used for redirects and email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
